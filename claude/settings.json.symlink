{
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "deniedPaths": ["~/.ssh", "~/.aws", "~/.gnupg", "~/.config"]
    },
    "network": {
      "allowedDomains": [],
      "mode": "restricted"
    }
  },
  "permissions": {
    "allow": [
      "Read(/tmp/**)",
      "Write(/tmp/**)"
    ]
  }
}